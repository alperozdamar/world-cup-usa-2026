spring.datasource.url=jdbc:mysql://localhost:3306/worldcup?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# Knockout preview: assign real teams to knockout slots and enable picks (local only)
app.knockout.dev-bootstrap=true

